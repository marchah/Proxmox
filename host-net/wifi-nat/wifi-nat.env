# Tunables for host-net/wifi-nat/install.sh.
#
# UNLIKE the pro-v620 .env files, this is sourced as BASH by install.sh (not by a
# systemd EnvironmentFile), so shell arrays are used for the reservation and
# port-forward lists. Secrets (SSID/passphrase) live in the gitignored
# wifi-nat.secrets.env, not here.

# Interfaces.
WAN_IF=wlo1          # onboard MediaTek MT7921K WiFi (the routed uplink)
LAN_IF=vmbr0         # internal bridge the LXCs sit on (becomes NAT'd private LAN)

# Private LAN the containers move onto. 10.10.10.0/24 is chosen to avoid the
# common Spectrum 192.168.1.0/24 (a WAN==LAN subnet overlap breaks routing).
LAN_ADDR=10.10.10.1
LAN_PREFIX=24
LAN_SUBNET=10.10.10.0/24

# DHCP pool handed to the containers (reservations below sit OUTSIDE this range).
DHCP_RANGE_START=10.10.10.50
DHCP_RANGE_END=10.10.10.199
DHCP_LEASE=12h
UPSTREAM_DNS="8.8.8.8 1.1.1.1"

# WiFi regulatory domain — REQUIRED to unlock 5 GHz (host boots at regdom 00).
COUNTRY=US

# Minutes before the cutover auto-reverts unless you run `install.sh --confirm`.
ROLLBACK_MINUTES=10
# Egress probe target for the --test-wifi / --cutover gates.
TEST_PING_IP=1.1.1.1

# Stable IPs for the LXCs, by MAC (matches their current net0 hwaddr). Format:
# "MAC IP HOSTNAME". Keep these outside DHCP_RANGE_START..END.
RESERVATIONS=(
  "BC:24:11:E1:42:30 10.10.10.120 llamacpp"
  "BC:24:11:66:CE:8D 10.10.10.121 hermes"
  "BC:24:11:9D:56:95 10.10.10.200 bench-runner"
)

# Inbound port-forwards (DNAT from the WiFi side to a container). Format:
# "PROTO EXT_PORT DEST_IP DEST_PORT". These expose the container services to the
# rest of the LAN once the host is behind NAT.
#   1234 -> llama.cpp OpenAI API (CT120) ; 8642 -> Hermes API (CT121)
#   9119 -> Hermes web dashboard (CT121, username/password auth)
# Add Plex once it lands, e.g.  "tcp 32400 10.10.10.NNN 32400"  (fill NNN in).
PORT_FORWARDS=(
  "tcp 1234 10.10.10.120 1234"
  "tcp 8642 10.10.10.121 8642"
  "tcp 9119 10.10.10.121 9119"
)
