# WiFi credentials for host-net/wifi-nat/install.sh.
#
# Copy this file to  wifi-nat.secrets.env  (which is gitignored) and fill in your
# network. install.sh runs `wpa_passphrase` on these to render the wpa_supplicant
# config; the plaintext passphrase never leaves this file.
#
#   cp wifi-nat.secrets.env.example wifi-nat.secrets.env
#   chmod 600 wifi-nat.secrets.env
#   $EDITOR wifi-nat.secrets.env

WIFI_SSID="YourNetworkName"
WIFI_PSK="YourWiFiPassphrase"
