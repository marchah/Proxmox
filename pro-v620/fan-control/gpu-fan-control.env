# Config for gpu-fan-control (installed to /etc/gpu-fan-control.env).
# Every value here is also the script's built-in default; this file just makes
# the chosen profile explicit and tunable without editing the script.
#
# NOTE: this file is read by systemd EnvironmentFile=, which does NOT strip
# trailing inline comments (everything after `=` is the value). Keep comments
# on their own lines, never after a VAR=value.
#
# Profile: "Quiet" — curve driven by the GPU EDGE temperature, with the HOTTEST
# of the hotspot sensors (junction + mem) forcing 100%. The V620 blower is the
# card's only cooling, so PWM_MIN_PCT keeps it spinning at idle (it does not
# stall below this). The fan is a powerful 9733 12V blower (doesn't stall even
# at 10%), and the GPU is idle most of the time, so the idle floor is set low.
#
#   edge <=35C -> 12.5% (raw 32 floor) | linear ramp | edge >=88C -> 100%
#   junction|mem >=90C -> 100% (resumes the curve at <=87C)

# Hardware mapping (change only if the blower is rewired to another header).
FAN_HWMON_NAME=nct6687
# PUMP_FAN1
FAN_PWM_CHANNEL=2
GPU_HWMON_NAME=amdgpu

# Curve (edge temperature -> PWM). PWM_MIN_PCT is the integer-% ramp anchor;
# the precise 12.5% idle floor is pinned by MIN_PWM_RAW=32 below.
EDGE_MIN_C=35
EDGE_MAX_C=88
PWM_MIN_PCT=12

# Hotspot safety override: the hottest of these sensors forces 100% (hysteresis).
HOTSPOT_TEMP_LABELS=junction mem
HOTSPOT_OVERRIDE_C=90
HOTSPOT_RESUME_C=87

# Loop behaviour.
POLL_INTERVAL=4
PWM_STEP=4
# absolute hard floor = idle floor: raw 32 ~= 12.5% (~747 RPM verified); never below
MIN_PWM_RAW=32

# Blower tach watchdog — the V620 is passively cooled, so a stalled/unplugged
# blower means NO cooling. If the tach reads < FAN_MIN_RPM while we command
# airflow for FAN_FAIL_GRACE consecutive polls, force 100% and act:
#   FAN_FAIL_ACTION=warn     -> log CRITICAL only (default; GPU hardware also
#                               throttles at 100C and emergency-stops ~105C)
#   FAN_FAIL_ACTION=poweroff -> power the host off to protect the GPU
# auto = watchdog on only if the tach reports RPM at startup (off for 2-wire fans).
FAN_RPM_MONITOR=auto
FAN_MIN_RPM=150
FAN_FAIL_GRACE=3
FAN_FAIL_ACTION=warn
FAN_FAIL_POWEROFF_GRACE=15
