# Config for gpu-fan-control@shroud (installed to /etc/gpu-fan-control-shroud.env).
# ONE NF-F12 iPPC-3000 in a shared shroud cools BOTH V620s, on the FAN1 header
# (nct6687 pwm3/fan3). The curve tracks the HOTTER of the two cards.
#
# systemd EnvironmentFile= does NOT strip trailing inline comments — keep comments
# on their own lines, never after a VAR=value.

FAN_LABEL=shroud
# Both V620s (comma-separated) — the fan cools both, so react to the hottest.
GPU_PCI_ADDRESS=0000:2d:00.0,0000:06:00.0
# NF-F12 on FAN1 = nct6687 pwm3/fan3 (verified: only spinning System-Fan channel).
FAN_PWM_CHANNEL=3

# Idle floor 50% (pwm 128, ~1480 RPM). The NF-F12 iPPC-3000 STALLS below ~47% and
# won't cold-start below ~43% (pwm 112) on this board, so the floor must sit above
# that — there is no quiet idle with this fan. Curve: edge <=45C -> 50% | ramp |
# edge >=80C -> 100%; junction/mem hotspot >=80C forces 100%. Upper ramp validated by
# the 2026-07-14 dual-GPU load test (split holds ~56-59C at 60% fan; see README.md).
EDGE_MIN_C=45
EDGE_MAX_C=80
PWM_MIN_PCT=50
MIN_PWM_RAW=128
HOTSPOT_TEMP_LABELS=junction mem
HOTSPOT_OVERRIDE_C=80
HOTSPOT_RESUME_C=77

FAN_RPM_MONITOR=auto
FAN_MIN_RPM=150
FAN_FAIL_ACTION=warn
