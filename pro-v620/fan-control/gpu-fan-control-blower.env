# Config for gpu-fan-control@blower (installed to /etc/gpu-fan-control-blower.env).
# The PCIe-1 (CPU-slot) V620, cooled by the 9733 blower on the Pump Fan header.
#
# systemd EnvironmentFile= does NOT strip trailing inline comments — keep comments
# on their own lines, never after a VAR=value.

FAN_LABEL=blower
# Pin the PCIe-1 card by PCI address (stable across boots; cardN is not). This host
# runs two V620s, so selection by address is required.
GPU_PCI_ADDRESS=0000:2d:00.0
# Pump Fan = pwm2/fan2 (verified empirically).
FAN_PWM_CHANNEL=2

# "Quiet" profile driven by EDGE temp; hottest of junction+mem forces 100%.
EDGE_MIN_C=35
EDGE_MAX_C=88
PWM_MIN_PCT=12
MIN_PWM_RAW=32
HOTSPOT_TEMP_LABELS=junction mem
HOTSPOT_OVERRIDE_C=90
HOTSPOT_RESUME_C=87

FAN_RPM_MONITOR=auto
FAN_MIN_RPM=150
FAN_FAIL_ACTION=warn
