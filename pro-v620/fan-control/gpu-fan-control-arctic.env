# Config for gpu-fan-control@arctic (installed to /etc/gpu-fan-control-arctic.env).
# The PCIe-3 (chipset-slot) V620, cooled by 2x Arctic S4028-6K (40mm, ~6000 RPM)
# on the "fan 2" header (nct6687 pwm4/fan4, "System Fan #2").
#
# systemd EnvironmentFile= does NOT strip trailing inline comments — keep comments
# on their own lines, never after a VAR=value.

FAN_LABEL=arctic
# Pin the PCIe-3 card by PCI address (stable across boots; cardN is not).
GPU_PCI_ADDRESS=0000:06:00.0
# Arctic S4028-6K x2 = pwm4/fan4 (verified: only channel that spins to ~6000 RPM).
FAN_PWM_CHANNEL=4

# Idle floor 22% (pwm 56 ~= 690 RPM) — the lowest PWM that reliably cold-starts the
# two S4028-6K on the splitter (stall below ~18%, no cold-start below ~21%). The idle
# GPU stays ~33-35C at this floor, so it is a noise/reliability choice, not thermal.
# Curve: edge <=40C -> 22% floor | linear ramp | edge >=85C -> 100%; junction/mem
# hotspot >=90C forces 100%. Upper ramp is conservative pending a sustained-load test.
EDGE_MIN_C=40
EDGE_MAX_C=85
PWM_MIN_PCT=22
MIN_PWM_RAW=56
HOTSPOT_TEMP_LABELS=junction mem
HOTSPOT_OVERRIDE_C=90
HOTSPOT_RESUME_C=87

FAN_RPM_MONITOR=auto
FAN_MIN_RPM=150
FAN_FAIL_ACTION=warn
