# Config for gpu-thermal-watchdog (installed to /etc/gpu-thermal-watchdog.env).
# Last-resort over-temp protection for the two Radeon Pro V620s: if either card's
# junction/mem crosses the trip temp, gracefully stop the LLM server so the card
# cools before the 105C hardware emergency reset. See ./README.md.
#
# systemd EnvironmentFile= does NOT strip trailing inline comments — keep comments
# on their own lines, never after a VAR=value.

# Watch both V620s (comma-separated PCI addresses; stable across boots). Empty =
# every amdgpu found.
GPU_PCI_ADDRESS=0000:2d:00.0,0000:06:00.0

# Trip point. 102C junction sits above the 100C throttle (a little throttling is
# fine) and below the 105C emergency reset — the last safety before the hardware
# has to reset the card. mem's emergency is 103C, so its trip is 101C.
TRIP_JUNCTION_C=102
TRIP_MEM_C=101
# Re-arm only after both drop below this (hysteresis).
RESUME_C=95

POLL_SECS=2

# stop = gracefully stop the owning service on a trip; warn = log only (for testing).
WATCHDOG_ACTION=stop
# Per-GPU stop map: which LXC service OWNS each card, so a trip stops the RIGHT one.
# Both V620s run a workload now — GPU 1 (0000:2d:00.0) = the ops model in CT 120;
# GPU 2 (0000:06:00.0) = the coding loop's llama-swap in CT 123. Without this the
# watchdog would stop CT 120 even when GPU 2 is the hot card. Format "PCI=VMID:service",
# comma-separated; an over-temp card NOT listed here stops EVERY mapped service.
GPU_SERVICE_MAP=0000:2d:00.0=120:llamacpp,0000:06:00.0=123:llama-swap
# Legacy fallback — used ONLY when GPU_SERVICE_MAP is empty: one service for every
# watched card (the pre-two-GPU behavior). Superseded by GPU_SERVICE_MAP above.
LLM_CT_VMID=120
LLM_SERVICE=llamacpp

# Leave the server stopped after a trip (default). Reaching 102C means cooling
# could not keep up, so a human should confirm it is safe before restarting rather
# than auto-resuming into the same overheating load. Set true to auto-restart once
# the card cools below RESUME_C.
AUTO_RESUME=false
