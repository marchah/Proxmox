# Config for gpu-undervolt (installed to /etc/gpu-undervolt.env).
# Every value here is also the script's built-in default; this file just makes
# the chosen offset explicit and tunable without editing the script.
#
# NOTE: this file is read by systemd EnvironmentFile=, which does NOT strip
# trailing inline comments (everything after `=` is the value). Keep comments
# on their own lines, never after a VAR=value.
#
# GFX voltage offset (undervolt) applied to the Radeon Pro V620 via amdgpu's
# OverDrive OD_VDDGFX_OFFSET. Negative = undervolt: lower voltage at the SAME
# clocks -> less power and heat. The V620's board power is firmware-locked at
# 250 W and OverDrive exposes no clock-ceiling knob, so this offset is the only
# available power/thermal lever (see README.md).
#
# Validated stable on this card at -100 mV: a full benchmark batch (single-user,
# concurrency 1-16, input-length 128-32768, soak) ran with ZERO GPU faults, and
# it measured -18% sustained board power (196 -> 160 W) and -8 C peak junction
# (83 -> 75 C) with throughput flat-to-+1%. If you ever see instability (GPU
# resets / ring timeouts under load), move the offset closer to 0 (e.g. -75).
OFFSET_MV=-100

# Tested-safe bounds: OFFSET_MV outside [OFFSET_MIN_MV, OFFSET_MAX_MV] (and any
# non-integer) is rejected before any hardware write. -100..0 is A/B-validated
# stable on this card; uncomment and widen only with your own stability data.
# DO NOT go deeper than -100 on the current card: a 2026-07-09 sweep found -125mV
# SILENTLY corrupts output under concurrent load (garbage tokens, no crash/fault)
# and -150mV hard-crashes the GPU (MODE1 reset). See README "Deeper-undervolt sweep".
#OFFSET_MIN_MV=-100
#OFFSET_MAX_MV=0

# Select the V620 by PCI vendor:device (lowercase, no 0x) so a non-V620 amdgpu GPU
# can never receive this offset. Default is the Radeon Pro V620 (Navi 21/gfx1030).
GPU_PCI_ID=1002:73a1
# Optional: pin an EXACT PCI address to undervolt just ONE card. Left unset, the
# service undervolts EVERY V620 in the box — this host has two (0000:2d:00.0 +
# 0000:06:00.0) and both get the offset.
#GPU_PCI_ADDRESS=

# Max seconds to wait at boot for the V620's pp_od_clk_voltage node to appear.
WAIT_SECS=30

# Wait for this many V620s before applying, so a card that binds a few seconds late
# at boot still gets the offset (this host has two). 0 = auto (stable-count, may miss
# a late 2nd card). Ignored when GPU_PCI_ADDRESS pins one card.
EXPECTED_GPU_COUNT=2
