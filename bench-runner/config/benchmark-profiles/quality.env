# Quality-oriented profile. lm-eval only runs when lm_eval is installed.
: "${BENCHMARK_PROMPTSET:=config/benchmark-promptsets/homelab-core.jsonl}"
: "${BENCHMARK_RUNS:=3}"
: "${BENCHMARK_REQUESTS:=${BENCHMARK_RUNS}}"
: "${BENCHMARK_CONCURRENCY:=1}"
: "${RUN_LM_EVAL:=true}"
: "${TELEMETRY_INTERVAL:=1}"
: "${BENCHMARK_SLO_FILE:=config/benchmark-slos/default.json}"
