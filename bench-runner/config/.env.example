# Template for run-remote-benchmark-suite.sh.
# Copy to config/.env (gitignored) and fill in, or point BENCHMARK_ENV_FILE at it.
# It runs the benchmark suite on a remote server over SSH and downloads results.

# --- Required ---
SERVER_HOST=192.0.2.10          # remote server hostname or IP
USER_NAME=youruser              # SSH username
USER_PASSWORD=changeme          # SSH password (used via sshpass)

# --- Optional (defaults shown) ---
# SSH_PORT=22
# SSH_STRICT_HOST_KEY_CHECKING=accept-new
# REMOTE_AI_LAB_DIR=/opt/bench-runner
# BENCHMARK_PROFILE=baseline
# BENCHMARK_RUN_ID=                       # default: <utc>-<profile>
# BENCHMARK_DESCRIPTION=Remote server-side benchmark run.
# RUN_LLAMA_BENCHY=true
# RUN_LM_EVAL=false
# MODEL_API_URL=http://127.0.0.1:1234/v1
# MODEL_IDENTIFIER=                       # auto-discovered if empty
# BENCHMARK_LOCAL_ROOT=                   # where results download locally (default: ./benchmarks)
