# loop-watchdog thresholds. Inactivity (IDLE_LIMIT) is the primary reap signal; the CAP_* are backstops.
IDLE_LIMIT=600
CAP_coder=2700
CAP_reviewer=1200
CAP_default=2700
# Reap notifications post to the #automation channel. Left unset here — the watchdog falls back to
# SLACK_AUTOMATION_CHANNEL from /root/.hermes/.env (see hermes.env.example). Set below only to override.
# WATCHDOG_SLACK_CHANNEL=
