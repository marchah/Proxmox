#!/usr/bin/env bash
# Resolve ALL unresolved review threads on a mealdeal PR (reply in-thread, then resolve). No-op if none.
# Called by the reviewer on PASS. Usage: resolve-pr-comments <pr#|branch> [reply]
set -uo pipefail
export PATH="/usr/local/bin:/usr/local/lib/hermes-agent/venv/bin:/usr/bin:/bin"
ARG="${1:?usage: resolve-pr-comments <pr#|branch> [reply]}"; REPLY="${2:-}"
[ -z "${MEALDEAL_GITHUB_TOKEN:-}" ] && [ -r /root/.hermes/.env ] && { set -a; . /root/.hermes/.env; set +a; }
export GH_TOKEN="${MEALDEAL_GITHUB_TOKEN:-}"
SLUG="$(git -C /root/repos/mealdeal remote get-url origin | sed -E 's#^[a-z]+://[^@]*@#https://#; s#^.*github\.com[:/]##; s#\.git$##')"
OWNER="${SLUG%%/*}"; REPO="${SLUG##*/}"
if [[ "$ARG" =~ ^[0-9]+$ ]]; then N="$ARG"; else
  N="$(gh pr list --repo "$SLUG" --head "$ARG" --state open --json number --jq '.[0].number // empty' 2>/dev/null)"
fi
[ -n "$N" ] || { echo "resolve-pr-comments: no open PR for '$ARG'" >&2; exit 1; }
SHA="$(gh pr view "$N" --repo "$SLUG" --json headRefOid --jq '.headRefOid[0:9]' 2>/dev/null)"
[ -n "$REPLY" ] || REPLY="Addressed in ${SHA:-latest} by the coder↔reviewer loop — reopen this thread if it is not fully resolved."
THREADS="$(pr-comments "$N" --json)"
CNT="$(printf '%s' "$THREADS" | jq 'length' 2>/dev/null || echo 0)"
[ "${CNT:-0}" -ge 1 ] || { echo "resolve-pr-comments: no unresolved threads on PR #$N"; exit 0; }
echo "resolve-pr-comments: resolving $CNT thread(s) on PR #$N"
printf '%s' "$THREADS" | jq -c '.[]' | while read -r t; do
  tid="$(printf '%s' "$t" | jq -r .threadId)"; cid="$(printf '%s' "$t" | jq -r .firstCommentId)"
  gh api "repos/$OWNER/$REPO/pulls/$N/comments" -f body="$REPLY" -F in_reply_to="$cid" >/dev/null 2>&1 || true
  if gh api graphql -F id="$tid" -f query='mutation($id:ID!){ resolveReviewThread(input:{threadId:$id}){ thread{ isResolved } } }' >/dev/null 2>&1; then
    echo "  resolved $(printf '%s' "$t" | jq -r '.path + ":" + (.line|tostring)')"
  else
    echo "  FAILED to resolve $tid"
  fi
done
