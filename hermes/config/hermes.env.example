# Loop/orchestrator environment — the vars the committed loop scripts read from /root/.hermes/.env.
#
# /root/.hermes/.env is GITIGNORED (never commit the real file). Add these keys to it and fill in real
# values, e.g.:  $EDITOR /root/.hermes/.env   (chmod 600). install.sh never writes this file.
#
# NOTE: the gateway's own credentials (Slack/Discord bot tokens, the API_SERVER_KEY) also live in
# /root/.hermes/.env, but they're set up by the base Hermes container (hermes/create-lxc-hermes-agent.sh),
# NOT by this loop config — so they're intentionally omitted here.

# ── Secret token (REQUIRED) ───────────────────────────────────────────────────────────────────────────
MEALDEAL_GITHUB_TOKEN=github_pat_xxx     # fine-grained PAT for the loop's target repo (Contents + Pull requests: write)

# ── Slack channel IDs parameterized out of the (public) committed loop scripts ──────────────────────────
SLACK_CODING_CHANNEL=C0XXXXXXXXX         # #coding — PR-ready notices + Codex/loop verdicts (codex-review, open-pr, loop-watchdog)
SLACK_AUTOMATION_CHANNEL=C0XXXXXXXXX     # #automation — loop-watchdog reap notifications
SLACK_PLANNING_CHANNEL=C0XXXXXXXXX       # #planning — the scope-and-plan planner channel (referenced in config.yaml)
